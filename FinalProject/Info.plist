	<string>AI Academic Mentor uses the camera for Focus Monitor (eye and head tracking) and to scan handwritten notes or math equations for AI analysis.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>AI Academic Mentor reads photos so you can scan your notes or math equations for AI-powered quiz generation and equation solving.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>AI Academic Mentor uses the microphone so you can speak your questions to the AI Tutor.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>AI Academic Mentor uses speech recognition to convert your voice into text for the AI Tutor.</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
		<key>UIImageName</key>
		<string>LaunchIcon</string>
		<key>UIImageRespectsSafeAreaLayoutGuide</key>
		<true/>
	</dict>
</dict>
